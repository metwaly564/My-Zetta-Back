generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  role      UserRole   @default(ADMIN)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
  contracts Contract[]
}

enum UserRole {
  ADMIN
  SALES
  B2B_CLIENT
  TECH
}

model Service {
  id                Int              @id @default(autoincrement())
  nameEn            String
  nameAr            String
  shortName         String
  descriptionEn     String
  descriptionAr     String
  icon              String
  taglineEn         String
  taglineAr         String
  savingsMultiplier Float
  monthlyRate       Float
  features          ServiceFeature[]
  benefits          ServiceBenefit[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  leads             Lead[]
}

model ServiceFeature {
  id        Int      @id @default(autoincrement())
  textEn    String
  textAr    String
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceBenefit {
  id        Int      @id @default(autoincrement())
  textEn    String
  textAr    String
  icon      String
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Partner {
  id         Int      @id @default(autoincrement())
  name       String
  logoUrl    String
  websiteUrl String?
  rank       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id                 Int        @id @default(autoincrement())
  name               String
  company            String
  email              String
  phone              String
  jobTitle           String?
  industry           String?
  serviceId          Int?
  service            Service?   @relation(fields: [serviceId], references: [id])
  deviceItems        Json? // Array of device items
  calculationResults Json? // ROI results
  type               LeadType   @default(CONTACT)
  status             LeadStatus @default(NEW)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

enum LeadType {
  CONTACT
  ROI
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model ComparisonLog {
  id         Int      @id @default(autoincrement())
  type       String // manual or file
  inputData  Json
  fileUrl    String?
  resultData Json
  createdAt  DateTime @default(now())
}

model Device {
  id           Int           @id @default(autoincrement())
  name         String
  serialNumber String        @unique
  status       DeviceStatus  @default(AVAILABLE)
  contractId   Int?
  contract     Contract?     @relation(fields: [contractId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum DeviceStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

model Contract {
  id             Int            @id @default(autoincrement())
  userId         Int
  user           User           @relation(fields: [userId], references: [id])
  status         ContractStatus @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  autoRenew      Boolean        @default(false)
  signatureState SignatureState @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  devices        Device[]
  invoices       Invoice[]
  extraServices  ExtraService[]
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum SignatureState {
  PENDING
  SIGNED_OTP
  SIGNED_NAFATH
}

model ExtraService {
  id         Int      @id @default(autoincrement())
  name       String
  cost       Float
  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         Int           @id @default(autoincrement())
  amount     Float
  status     InvoiceStatus @default(UNPAID)
  dueDate    DateTime
  contractId Int
  contract   Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  details   Json?
  createdAt DateTime @default(now())
}

model Client {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  department String?
  email      String?
  phone      String?
  address    String?
  logoUrl    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sites      Site[]
}

model Site {
  id         Int      @id @default(autoincrement())
  name       String
  clientId   Int
  client     Client   @relation(fields: [clientId], references: [id])
  clientCode String
  city       String
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  assets     Asset[]
}

model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String
  city        String
  address     String
  managerName String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
}

model AssetCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  categoryCode String   @default("GEN")
  createdAt    DateTime @default(now())
}

model Asset {
  id                 Int            @id @default(autoincrement())
  assetTag           String         @unique
  serialNumber       String         @unique
  category           String
  model              String
  vendor             String
  status             String         @default("In Warehouse")
  warehouseId        Int?
  warehouse          Warehouse?     @relation(fields: [warehouseId], references: [id])
  assignedUser       String?
  assignedDepartment String?
  assignedLocation   String?
  warrantyExpiry     String?
  leaseStart         String?
  leaseEnd           String?
  monthlyRate        Float?
  notes              String?
  contractId         Int?
  siteId             Int?
  site               Site?          @relation(fields: [siteId], references: [id])
  receivingRecordId  Int?
  releasePOId        Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  history            AssetHistory[]
}

model AssetHistory {
  id          Int      @id @default(autoincrement())
  assetId     Int
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  eventType   String
  description String
  performedBy String?
  createdAt   DateTime @default(now())
}
